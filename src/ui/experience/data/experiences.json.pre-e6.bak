      "venue": {
        "name": null,
        "url": null,
        "type": "anywhere",
        "region": "nationwide"
      },
      "description": "Wherever that is - their school, their street, their church or social club Not a nostalgic gesture. A genuine piece of fieldwork.",
      "why_it_works": "You ask them questions as you walk. The place unlocks memories that don't surface at a dinner table. You'll hear things you've never heard before. Record it on your phone.",
      "experience_types": [
        "recovery"
      ],
      "bookable": true,
      "seasonal": false
    },
