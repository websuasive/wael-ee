      {
        "direction_name": "Contributor",
        "direction_engine_name": "contributor",
        "summary": {
          "interpretive_text": null,
          "token_text": ""
        },
        "meaning_sentence": {
          "interpretive_text": "The pull is to be useful in a way that actually counts - to know that something you did genuinely helped, mattered to someone, left things better than you found them. It isn't about the thanks or the credit; if anything those get in the way. Often it comes from competence with nowhere good to point it: you're good at things, and you want that to land on someone who needed it. When your effort makes a real difference, the work feels worth doing. When it's just motion - busy, billed, forgotten - it goes hollow, however much of it there is.",
          "token_text": ""
        },
        "fields": [
