      },
      {
        "direction_name": "Experience Seeker",
        "direction_engine_name": "experience_seeker",
        "summary": {
          "interpretive_text": null,
          "token_text": ""
        },
        "meaning_sentence": {
          "interpretive_text": "The pull is toward newness - new places, new things, the feeling of being properly in your life rather than watching it pass. Underneath it, usually, is time: the sense that the years are going and you don't want to use them up on repetition. It isn't restlessness for its own sake. It's that you come alive in the unfamiliar, and a life that's become the same week on repeat starts to feel like it's narrowing around you. Variety isn't a luxury for you; it's most of how you know you're still living.",
          "token_text": ""
        },
