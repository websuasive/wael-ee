      {
        "direction_name": "Growth Focused",
        "direction_engine_name": "growth_focused",
        "summary": {
          "interpretive_text": null,
          "token_text": ""
        },
        "meaning_sentence": {
          "interpretive_text": "The pull is to keep getting sharper - to be tested, to push against something real, to feel capable rather than just competent. Part of it is age: the wish to feel as able as you once did. Part of it is plainer than that - you come alive when something stretches you, and you go flat when nothing does. It isn't about courses or self-improvement for its own sake. It's the difference between rising to something and ticking over. Coasting might look like rest, but for you it reads as standing still, and standing still doesn't sit right.",
          "token_text": ""
        },
